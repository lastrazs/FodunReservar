@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Recuperar contrasena";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <h1 class="h3 mb-3">Recuperar contrasena</h1>
        <p class="text-muted">Ingrese su numero de documento. Si el usuario existe, enviaremos el enlace de recuperacion al correo registrado.</p>

        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="NroDocumento" class="form-label"></label>
                <input asp-for="NroDocumento" class="form-control" />
                <span asp-validation-for="NroDocumento" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Enviar correo</button>
            <a asp-action="Login" class="btn btn-link">Volver al login</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
