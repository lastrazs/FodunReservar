@model ReservasIndexViewModel
@{
    ViewData["Title"] = "Sedes";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h1 class="display-6 mb-1">Sedes disponibles</h1>
            <p class="text-muted mb-0">Selecciona una sede para consultar disponibilidad por fechas y numero de personas.</p>
        </div>
        <a class="btn btn-outline-primary" asp-action="Disponibilidad">Busqueda manual</a>
    </div>

    @if (!Model.Sedes.Any())
    {
        <div class="alert alert-warning mb-0">
            No hay sedes activas configuradas en este momento.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var sede in Model.Sedes)
            {
                <div class="col-lg-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <h2 class="h4 mb-1">@sede.Nombre</h2>
                                    <div class="text-muted">@sede.TipoSede - @sede.Ubicacion</div>
                                </div>
                                <span class="badge bg-light text-dark">@sede.TipoSede</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(sede.Descripcion))
                            {
                                <p class="mb-3">@sede.Descripcion</p>
                            }

                            <dl class="row mb-3">
                                <dt class="col-sm-4">Direccion</dt>
                                <dd class="col-sm-8">@(!string.IsNullOrWhiteSpace(sede.Direccion) ? sede.Direccion : "No registrada")</dd>

                                <dt class="col-sm-4">Lavanderia</dt>
                                <dd class="col-sm-8">@(sede.TieneServicioLavanderia ? $"Si, ${sede.ValorLavanderia:N0}" : "No")</dd>

                                <dt class="col-sm-4">Acompanantes</dt>
                                <dd class="col-sm-8">@(sede.PermiteAcompanantes ? $"Permitidos, ${sede.ValorAcompanante:N0}" : "No permitidos")</dd>
                            </dl>

                            <a class="btn btn-primary" asp-action="Disponibilidad" asp-route-sedeId="@sede.Id">
                                Consultar disponibilidad
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
