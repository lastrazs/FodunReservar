@model ConfirmarReservaViewModel
@{
    ViewData["Title"] = "Confirmar reserva";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h1 class="display-6 mb-1">Confirmar reserva</h1>
            <p class="text-muted mb-0">La tarifa y el total se recalculan consumiendo `sp_ConsultarTarifas` y `sp_CalcularTotalReserva` antes de guardar la reserva.</p>
        </div>
        <a class="btn btn-outline-secondary"
           asp-action="Disponibilidad"
           asp-route-sedeId="@Model.SedeId"
           asp-route-fechaEntrada="@Model.FechaEntrada.ToString("yyyy-MM-dd")"
           asp-route-fechaSalida="@Model.FechaSalida.ToString("yyyy-MM-dd")"
           asp-route-nroPersonas="@Model.NroPersonas">
            Volver a disponibilidad
        </a>
    </div>

    <form asp-action="Confirmar" method="post" class="row g-4">
        @Html.AntiForgeryToken()
        <input asp-for="SedeId" type="hidden" />
        <input asp-for="AlojamientoId" type="hidden" />
        <input asp-for="FechaEntrada" type="hidden" />
        <input asp-for="FechaSalida" type="hidden" />
        <input asp-for="NroPersonas" type="hidden" />

        <div class="col-lg-7">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h4 mb-3">Resumen del alojamiento</h2>

                    <dl class="row mb-0">
                        <dt class="col-sm-4">Sede</dt>
                        <dd class="col-sm-8">@Model.SedeNombre - @Model.SedeUbicacion</dd>

                        <dt class="col-sm-4">Alojamiento</dt>
                        <dd class="col-sm-8">@Model.NumeroAlojamiento (@Model.TipoAlojamiento)</dd>

                        <dt class="col-sm-4">Descripcion</dt>
                        <dd class="col-sm-8">@(!string.IsNullOrWhiteSpace(Model.Descripcion) ? Model.Descripcion : "Sin descripcion")</dd>

                        <dt class="col-sm-4">Capacidad</dt>
                        <dd class="col-sm-8">@Model.CapacidadMaxima persona(s)</dd>

                        <dt class="col-sm-4">Habitaciones</dt>
                        <dd class="col-sm-8">@Model.NroHabitaciones</dd>

                        <dt class="col-sm-4">Fechas</dt>
                        <dd class="col-sm-8">@Model.FechaEntrada.ToString("yyyy-MM-dd") al @Model.FechaSalida.ToString("yyyy-MM-dd")</dd>

                        <dt class="col-sm-4">Noches</dt>
                        <dd class="col-sm-8">@Model.NumeroNoches</dd>

                        <dt class="col-sm-4">Personas</dt>
                        <dd class="col-sm-8">@Model.NroPersonas</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h4 mb-3">Tarifa aplicada</h2>

                    <dl class="row mb-0">
                        <dt class="col-sm-7">Temporada</dt>
                        <dd class="col-sm-5">@Model.Temporada</dd>

                        <dt class="col-sm-7">Personas incluidas</dt>
                        <dd class="col-sm-5">@Model.PersonasIncluidas</dd>

                        <dt class="col-sm-7">Personas adicionales</dt>
                        <dd class="col-sm-5">@Model.PersonasAdicionales</dd>

                        <dt class="col-sm-7">Valor noche</dt>
                        <dd class="col-sm-5">$@Model.ValorNoche.ToString("N0")</dd>

                        <dt class="col-sm-7">Valor adicional por persona</dt>
                        <dd class="col-sm-5">$@Model.ValorPersonaAdicional.ToString("N0")</dd>

                        <dt class="col-sm-7">Subtotal noches</dt>
                        <dd class="col-sm-5">$@Model.SubtotalNoches.ToString("N0")</dd>

                        <dt class="col-sm-7">Valor adicionales</dt>
                        <dd class="col-sm-5">$@Model.ValorAdicionales.ToString("N0")</dd>

                        <dt class="col-sm-7">Acompanantes</dt>
                        <dd class="col-sm-5">$@Model.ValorAcompanantes.ToString("N0")</dd>

                        <dt class="col-sm-7">Lavanderia</dt>
                        <dd class="col-sm-5">$@Model.ValorLavanderia.ToString("N0")</dd>

                        <dt class="col-sm-7">Servicios adicionales</dt>
                        <dd class="col-sm-5">$@Model.TotalServicios.ToString("N0")</dd>

                        <dt class="col-sm-7 fw-bold">Total reserva</dt>
                        <dd class="col-sm-5 fw-bold">$@Model.TotalReserva.ToString("N0")</dd>
                    </dl>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    @if (Model.PermiteAcompanantes)
                    {
                        <div class="mb-3">
                            <label asp-for="NroAcompanantes" class="form-label">Acompanantes de visita</label>
                            <input asp-for="NroAcompanantes" class="form-control" type="number" min="0" max="10" />
                            <div class="small text-muted">
                                Valor unitario: $@Model.ValorAcompananteUnidad.ToString("N0")
                            </div>
                            <span asp-validation-for="NroAcompanantes" class="text-danger small"></span>
                        </div>
                    }

                    @if (Model.TieneServicioLavanderia)
                    {
                        <div class="form-check mb-3">
                            <input asp-for="RequiereLavanderia" class="form-check-input" />
                            <label asp-for="RequiereLavanderia" class="form-check-label">
                                Agregar servicio de lavanderia ($@Model.ValorLavanderiaUnidad.ToString("N0"))
                            </label>
                        </div>
                    }

                    <label asp-for="Observaciones" class="form-label">Observaciones</label>
                    <textarea asp-for="Observaciones" class="form-control" rows="4" placeholder="Dato adicional para la reserva"></textarea>
                    <span asp-validation-for="Observaciones" class="text-danger small"></span>

                    <div class="small text-muted mt-3">
                        La reserva se registra en estado <strong>Pendiente</strong> y bloquea el alojamiento para el rango de fechas consultado.
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mt-3">Guardar reserva</button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
