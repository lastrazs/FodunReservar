@model AlojamientoFormViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Nuevo alojamiento" : "Editar alojamiento";
}

<div class="py-4">
    <h1 class="display-6 mb-4">@ViewData["Title"]</h1>

    <form method="post" class="row g-3">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-6">
            <label asp-for="SedeId" class="form-label">Sede</label>
            <select asp-for="SedeId" asp-items="Model.Sedes" class="form-select">
                <option value="">Selecciona una sede</option>
            </select>
            <span asp-validation-for="SedeId" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="TipoAlojamientoId" class="form-label">Tipo de alojamiento</label>
            <select asp-for="TipoAlojamientoId" asp-items="Model.TiposAlojamiento" class="form-select">
                <option value="">Selecciona un tipo</option>
            </select>
            <span asp-validation-for="TipoAlojamientoId" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="NumeroAlojamiento" class="form-label"></label>
            <input asp-for="NumeroAlojamiento" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="CapacidadMaxima" class="form-label"></label>
            <input asp-for="CapacidadMaxima" class="form-control" type="number" min="1" />
        </div>
        <div class="col-md-4">
            <label asp-for="NumeroHabitaciones" class="form-label"></label>
            <input asp-for="NumeroHabitaciones" class="form-control" type="number" min="1" />
        </div>
        <div class="col-12">
            <label asp-for="Descripcion" class="form-label"></label>
            <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-12">
            <div class="row g-3">
                <div class="col-md-3 form-check">
                    <input asp-for="TieneBano" class="form-check-input" />
                    <label asp-for="TieneBano" class="form-check-label"></label>
                </div>
                <div class="col-md-3 form-check">
                    <input asp-for="TieneCocineta" class="form-check-input" />
                    <label asp-for="TieneCocineta" class="form-check-label"></label>
                </div>
                <div class="col-md-3 form-check">
                    <input asp-for="TieneTelevision" class="form-check-input" />
                    <label asp-for="TieneTelevision" class="form-check-label"></label>
                </div>
                <div class="col-md-3 form-check">
                    <input asp-for="TieneNevera" class="form-check-input" />
                    <label asp-for="TieneNevera" class="form-check-label"></label>
                </div>
                <div class="col-md-3 form-check">
                    <input asp-for="TieneTerraza" class="form-check-input" />
                    <label asp-for="TieneTerraza" class="form-check-label"></label>
                </div>
                <div class="col-md-3 form-check">
                    <input asp-for="TieneSalaEstar" class="form-check-input" />
                    <label asp-for="TieneSalaEstar" class="form-check-label"></label>
                </div>
                <div class="col-md-3 form-check">
                    <input asp-for="TieneParqueadero" class="form-check-input" />
                    <label asp-for="TieneParqueadero" class="form-check-label"></label>
                </div>
                <div class="col-md-3 form-check">
                    <input asp-for="EsNuevo" class="form-check-input" />
                    <label asp-for="EsNuevo" class="form-check-label"></label>
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="form-check">
                <input asp-for="Activo" class="form-check-input" />
                <label asp-for="Activo" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Guardar</button>
            <a class="btn btn-outline-secondary" asp-action="Alojamientos">Volver</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
