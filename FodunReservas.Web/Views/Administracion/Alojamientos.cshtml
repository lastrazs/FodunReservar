@model AlojamientosAdminListViewModel
@{
    ViewData["Title"] = "Alojamientos";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h1 class="display-6 mb-1">Alojamientos</h1>
            <p class="text-muted mb-0">Configuracion operativa de unidades reservables.</p>
        </div>
        <a class="btn btn-primary" asp-action="CrearAlojamiento">Nuevo alojamiento</a>
    </div>

    @if (TempData["AdminSuccess"] is string adminSuccess)
    {
        <div class="alert alert-success">@adminSuccess</div>
    }

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Sede</th>
                    <th>Tipo</th>
                    <th>Numero</th>
                    <th>Capacidad</th>
                    <th>Habitaciones</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var alojamiento in Model.Alojamientos)
            {
                <tr>
                    <td>@alojamiento.SedeNombre</td>
                    <td>@alojamiento.TipoAlojamientoNombre</td>
                    <td>@alojamiento.NumeroAlojamiento</td>
                    <td>@alojamiento.CapacidadMaxima</td>
                    <td>@alojamiento.NumeroHabitaciones</td>
                    <td>@(alojamiento.Activo ? "Activo" : "Inactivo")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="EditarAlojamiento" asp-route-id="@alojamiento.Id">Editar</a>
                        <form asp-action="CambiarEstadoAlojamiento" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@alojamiento.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Activar / Desactivar</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
