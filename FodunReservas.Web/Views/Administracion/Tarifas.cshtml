@model TarifasAdminListViewModel
@{
    ViewData["Title"] = "Tarifas";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h1 class="display-6 mb-1">Tarifas</h1>
            <p class="text-muted mb-0">Valores base por sede, temporada y numero de habitaciones.</p>
        </div>
        <a class="btn btn-primary" asp-action="CrearTarifa">Nueva tarifa</a>
    </div>

    @if (TempData["AdminSuccess"] is string adminSuccess)
    {
        <div class="alert alert-success">@adminSuccess</div>
    }

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Sede</th>
                    <th>Temporada</th>
                    <th>Habitaciones</th>
                    <th>Personas base</th>
                    <th>Valor noche</th>
                    <th>Valor adicional</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var tarifa in Model.Tarifas)
            {
                <tr>
                    <td>@tarifa.SedeNombre</td>
                    <td>@tarifa.TemporadaNombre</td>
                    <td>@tarifa.NumeroHabitaciones</td>
                    <td>@tarifa.PersonasBase</td>
                    <td>$@tarifa.ValorNoche.ToString("N0")</td>
                    <td>$@tarifa.ValorPersonaAdicional.ToString("N0")</td>
                    <td>@(tarifa.Activa ? "Activa" : "Inactiva")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="EditarTarifa" asp-route-id="@tarifa.Id">Editar</a>
                        <form asp-action="CambiarEstadoTarifa" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@tarifa.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Activar / Desactivar</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
