@model SedeFormViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Nueva sede" : "Editar sede";
}

<div class="py-4">
    <h1 class="display-6 mb-4">@ViewData["Title"]</h1>

    <form method="post" class="row g-3">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-4">
            <label asp-for="TipoSede" class="form-label"></label>
            <select asp-for="TipoSede" class="form-select">
                <option value="Sede Recreativa">Sede Recreativa</option>
                <option value="Apartamento">Apartamento</option>
            </select>
        </div>
        <div class="col-md-8">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Ubicacion" class="form-label"></label>
            <input asp-for="Ubicacion" class="form-control" />
            <span asp-validation-for="Ubicacion" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Direccion" class="form-label"></label>
            <input asp-for="Direccion" class="form-control" />
        </div>
        <div class="col-12">
            <label asp-for="Descripcion" class="form-label"></label>
            <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input asp-for="PermiteAcompanantes" class="form-check-input" />
                <label asp-for="PermiteAcompanantes" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <label asp-for="ValorAcompanante" class="form-label"></label>
            <input asp-for="ValorAcompanante" class="form-control" type="number" step="0.01" />
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input asp-for="TieneServicioLavanderia" class="form-check-input" />
                <label asp-for="TieneServicioLavanderia" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <label asp-for="ValorLavanderia" class="form-label"></label>
            <input asp-for="ValorLavanderia" class="form-control" type="number" step="0.01" />
        </div>
        <div class="col-12">
            <div class="form-check">
                <input asp-for="Activa" class="form-check-input" />
                <label asp-for="Activa" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Guardar</button>
            <a class="btn btn-outline-secondary" asp-action="Sedes">Volver</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
