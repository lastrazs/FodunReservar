@model TemporadasAdminListViewModel
@{
    ViewData["Title"] = "Temporadas";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h1 class="display-6 mb-1">Temporadas</h1>
            <p class="text-muted mb-0">Prioridades y ventanas de negocio para el calculo tarifario.</p>
        </div>
        <a class="btn btn-primary" asp-action="CrearTemporada">Nueva temporada</a>
    </div>

    @if (TempData["AdminSuccess"] is string adminSuccess)
    {
        <div class="alert alert-success">@adminSuccess</div>
    }

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Descripcion</th>
                    <th>Prioridad</th>
                    <th>Especial</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var temporada in Model.Temporadas)
            {
                <tr>
                    <td>@temporada.Nombre</td>
                    <td>@temporada.Descripcion</td>
                    <td>@temporada.Prioridad</td>
                    <td>@(temporada.EsEspecial ? "Si" : "No")</td>
                    <td>@(temporada.Activa ? "Activa" : "Inactiva")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="EditarTemporada" asp-route-id="@temporada.Id">Editar</a>
                        <form asp-action="CambiarEstadoTemporada" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@temporada.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Activar / Desactivar</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
