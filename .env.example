# ============================================================
# FodunReservas - Environment Configuration Example
# ============================================================
# Copia este archivo a .env y completa con tus valores
# IMPORTANTE: Nunca commitear .env a Git (está en .gitignore)
# ============================================================

# ============================================================
# Base de Datos
# ============================================================

# Cadena de conexión a SQL Server
# Formatos comunes:
#  - Autenticación integrada: Server=localhost;Database=FodunReservas;Integrated Security=true;
#  - Autenticación por usuario: Server=localhost;Database=FodunReservas;User Id=sa;Password=tu_pass;
#  - SQL Server Express: Server=.\SQLEXPRESS;Database=FodunReservas;Integrated Security=true;
#  - LocalDB: Server=(localdb)\mssqllocaldb;Database=FodunReservas;Integrated Security=true;

DB_CONNECTION_STRING=Server=localhost;Database=FodunReservas;Integrated Security=true;Encrypt=False;TrustServerCertificate=True;

# ============================================================
# SMTP - Correo Electrónico
# ============================================================

# Usar directorio de pickup en desarrollo (guarda emails localmente)
SMTP_USE_PICKUP_DIRECTORY=true
SMTP_PICKUP_DIRECTORY=App_Data/Emails

# O configurar SMTP real para producción:
# SMTP_USE_PICKUP_DIRECTORY=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_ENABLE_SSL=true
# SMTP_USERNAME=tu-email@gmail.com
# SMTP_PASSWORD=__SET_VIA_ENV_OR_SECRET_STORE__
# SMTP_FROM_EMAIL=tu-email@gmail.com
# SMTP_FROM_NAME=FodunReservas

# ============================================================
# Logging
# ============================================================

# Niveles: Trace, Debug, Information, Warning, Error, Critical, None
LOG_LEVEL=Information
LOG_ASPNETCORE_LEVEL=Warning

# ============================================================
# Seguridad
# ============================================================

# CORS - Orígenes permitidos (desarrollo)
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT (si se implementa en futuro)
JWT_SECRET_KEY=tu-clave-secreta-minimo-32-caracteres-aleatorios-aqui

# ============================================================
# Aplicación
# ============================================================

# Ambiente: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Development

# Puerto (opcional)
# ASPNETCORE_URLS=https://localhost:7000

# ============================================================
# Notas de Uso
# ============================================================

# 1. Copia este archivo:
#    cp .env.example .env
#
# 2. Edita .env con tus configuraciones locales
#
# 3. En Program.cs, cargar variables:
#    var connectionString = builder.Configuration["DB_CONNECTION_STRING"];
#    var smtpHost = builder.Configuration["SMTP_HOST"];
#
# 4. .env está en .gitignore - no se commitea
#
# 5. Para producción, usar ConfigurationManager o Azure Key Vault
