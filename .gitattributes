# Git attributes - Normalización de saltos de línea

# Auto line-ending conversion
* text=auto

# ============================================================
# Archivos con saltos de línea nativos
# ============================================================

# Archivos de texto
*.txt text eol=crlf
*.md text eol=crlf
*.markdown text eol=crlf

# Archivos de código
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.html text eol=crlf
*.css text eol=crlf
*.js text eol=crlf
*.ts text eol=crlf
*.json text eol=crlf
*.xml text eol=crlf
*.sql text eol=crlf
*.yaml text eol=crlf
*.yml text eol=crlf
*.ps1 text eol=crlf

# ============================================================
# Archivos binarios (no convertir)
# ============================================================

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
*.fnt binary

# ============================================================
# Archivos de configuración de desarrollador
# ============================================================

.vscode/** text eol=crlf merge=union
.idea/** text merge=union
